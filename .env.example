# Copier ce fichier en .env et remplir les valeurs

# Identifiants Vinted
VINTED_USERNAME=ton_email_ou_pseudo
VINTED_PASSWORD=ton_mot_de_passe

# Domaine Vinted (fr, be, lu, etc.)
VINTED_DOMAIN=fr

# Intervalle de vérification en secondes (300 = 5 minutes)
CHECK_INTERVAL_SECONDS=300

# Chemin du fichier d'état
STATE_FILE=data/state.json
