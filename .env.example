# Copier ce fichier en .env et remplir les valeurs

# Tokens Vinted (récupérés depuis les cookies du navigateur)
VINTED_ACCESS_TOKEN=colle_access_token_ici
VINTED_REFRESH_TOKEN=colle_refresh_token_ici

# Domaine Vinted (fr, be, lu, etc.)
VINTED_DOMAIN=fr

# Intervalle de vérification en secondes (300 = 5 minutes)
CHECK_INTERVAL_SECONDS=300

# Chemin du fichier d'état
STATE_FILE=data/state.json
