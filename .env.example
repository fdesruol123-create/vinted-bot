# Copier ce fichier en .env et remplir les valeurs

# Cookie de session Vinted (voir guide ci-dessous pour le récupérer)
VINTED_SESSION_COOKIE=colle_ton_cookie_ici

# Domaine Vinted (fr, be, lu, etc.)
VINTED_DOMAIN=fr

# Intervalle de vérification en secondes (300 = 5 minutes)
CHECK_INTERVAL_SECONDS=300

# Chemin du fichier d'état
STATE_FILE=data/state.json
